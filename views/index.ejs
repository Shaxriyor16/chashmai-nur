<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<title>Chashmai Nur — Menyu</title>
<style>
body {margin:0;font-family:Arial,sans-serif;display:flex;}
.sidebar {width:220px;background:#111;color:#fff;min-height:100vh;padding:20px;}
.sidebar .logo{text-align:center;margin-bottom:20px;}
.sidebar .logo img{width:80px;border-radius:50%;}
.sidebar h2{font-size:18px;margin-top:10px;color:gold;}
.menu-nav button{display:block;width:100%;margin:5px 0;padding:10px;background:#222;color:#fff;border:none;border-radius:8px;cursor:pointer;text-align:left;}
.menu-nav button:hover{background:gold;color:#111;}
.content{flex:1;padding:20px;position:relative;}
header h1{margin:0;color:#222;}
.contact-info{font-size:14px;color:#fff;background:#111;display:inline-block;padding:8px 12px;border-radius:8px;}
.contact-info a{color:#fff;text-decoration:none;font-weight:bold;}
.contact-info a:hover{text-decoration:underline;}
#menuGrid{display:flex;flex-wrap:wrap;gap:15px;margin-top:20px;}
.food-card{position:relative;background:#f5f5f5;border-radius:12px;padding:10px;width:200px;box-shadow:0 2px 6px rgba(0,0,0,0.2);}
.food-card img{width:100%;border-radius:10px;}
.food-card h3{margin:8px 0 4px 0;font-size:16px;color:#111;}
.food-card p{margin:0;font-size:14px;color:#333;}
.new-label{position:absolute;top:8px;left:8px;background:red;color:#fff;font-size:12px;font-weight:bold;padding:2px 6px;border-radius:4px;z-index:10;}
.hamburger{display:none;font-size:24px;cursor:pointer;padding:10px;position:fixed;top:10px;left:10px;z-index:1001;color:#fff;}
@media (max-width:768px){body{flex-direction:column;}.sidebar{position:fixed;top:0;left:0;height:100vh;z-index:1000;transform:translateX(-100%);}.sidebar.open{transform:translateX(0);}.hamburger{display:block;}.content{padding-top:50px;}}
</style>
</head>
<body>
<div class="hamburger" id="hamburger">☰</div>
<aside class="sidebar" id="sidebar">
  <div class="logo">
    <img src="/images/Chashmai-nur.jpg" alt="Logotip" class="logo">
    <h2>Chashmai Nur</h2>
  </div>
  <nav class="menu-nav">
    <button data-cat="salat">🥗 Salatlar</button>
    <button data-cat="asosiy">🍲 Asosiy taomlar</button>
    <button data-cat="gosht">🍖 Go‘shtli taomlar</button>
    <button data-cat="baliq">🐟 Baliq</button>
    <button data-cat="shashlik">🍢 Shashliklar</button>
    <button data-cat="desert">🍰 Desertlar</button>
    <button data-cat="ichimlik">☕ Ichimliklar</button>
  </nav>
</aside>
<main class="content">
<header>
  <h1>Menyu</h1>
  <div class="contact-info">📞 <a href="tel:+998974128074">+998 97 412 80 74</a></div>
</header>
<div id="menuGrid">
<% foods.forEach(food => { %>
  <div class="food-card">
    <% if(food.new){ %>
      <div class="new-label">NEW</div>
    <% } %>
    <img src="<%= food.image %>" alt="<%= food.name %>">
    <h3><%= food.name %></h3>
    <p><%= food.description %> — <%= food.price %> so'm</p>
  </div>
<% }); %>
</div>
</main>
<script>
const hamburger = document.getElementById("hamburger");
const sidebar = document.getElementById("sidebar");
hamburger.addEventListener("click",()=>{sidebar.classList.toggle("open");});
</script>
</body>
</html>
