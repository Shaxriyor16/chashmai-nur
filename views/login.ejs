<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <style>
    body{background:#111;color:#fff;display:flex;justify-content:center;align-items:center;height:100vh;margin:0;font-family:Arial;}
    .login-box{background:#1e1e1e;padding:30px;border-radius:15px;width:350px;text-align:center;box-shadow:0 0 20px rgba(255,215,0,0.3);}
    h1{color:gold;margin-bottom:20px;}
    input,button{width:100%;padding:12px;margin:10px 0;border:none;border-radius:8px;}
    input{background:#2a2a2a;color:#fff;}
    input:focus{outline:2px solid gold;}
    button{background:gold;color:#111;font-weight:bold;cursor:pointer;}
    button:hover{background:#ffcc00;}
  </style>
</head>
<body>
  <div class="login-box">
    <h1>🔑 Admin Login</h1>
    <form method="POST" action="/login">
      <input type="text" name="phone" placeholder="Telefon: 996479888" required>
      <input type="password" name="password" placeholder="Parol: 1234" required>
      <button type="submit">Kirish</button>
    </form>
  </div>
</body>
</html>
